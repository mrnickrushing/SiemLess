# ── Database ──────────────────────────────────────────────────────────────────
# Railway provides postgresql:// or postgres:// — both are auto-converted.
DATABASE_URL=postgresql+asyncpg://siemless:siemless_secret@postgres:5432/siemless

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_URL=redis://redis:6379

# ── Security (REQUIRED in production) ────────────────────────────────────────
# Generate with: openssl rand -hex 32
SECRET_KEY=CHANGE_ME_openssl_rand_hex_32

# Admin login credentials for the web UI
ADMIN_USERNAME=admin
ADMIN_PASSWORD=CHANGE_ME_strong_password

# ── CORS ──────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed origins, or * for development only.
# Example: https://your-app.railway.app,https://yourdomain.com
CORS_ORIGINS=*

# ── Syslog listener ───────────────────────────────────────────────────────────
SYSLOG_HOST=0.0.0.0
SYSLOG_PORT=514

# ── Threat Intelligence (optional) ───────────────────────────────────────────
THREAT_INTEL_ABUSEIPDB_KEY=
THREAT_INTEL_VIRUSTOTAL_KEY=

# ── Email alerts (optional) ───────────────────────────────────────────────────
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
ALERT_EMAIL=

# ── Slack alerts (optional) ───────────────────────────────────────────────────
SLACK_WEBHOOK_URL=

# ── Session ───────────────────────────────────────────────────────────────────
# JWT session cookie lifetime in minutes (default 60). Tokens are httpOnly
# cookies — not accessible to JavaScript. Adjust for your org's policy.
# ACCESS_TOKEN_EXPIRE_MINUTES=60

# ── Development ───────────────────────────────────────────────────────────────
# Set to true to skip SECRET_KEY / ADMIN_PASSWORD strength checks.
# WARNING: ADMIN_PASSWORD must still be set even in DEBUG mode.
DEBUG=false
