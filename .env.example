# Copy to .env and fill in values

# Database
DATABASE_URL=postgresql+asyncpg://siemless:siemless_secret@postgres:5432/siemless

# Redis
REDIS_URL=redis://redis:6379

# Security
SECRET_KEY=change-me-run-openssl-rand-hex-32

# Syslog listener
SYSLOG_HOST=0.0.0.0
SYSLOG_PORT=514

# Threat Intelligence (optional)
THREAT_INTEL_ABUSEIPDB_KEY=
THREAT_INTEL_VIRUSTOTAL_KEY=

# Email alerts (optional)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
ALERT_EMAIL=

# Slack alerts (optional)
SLACK_WEBHOOK_URL=
